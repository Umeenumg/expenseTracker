   <string notr="true">/* ═══════════════════════════════════════
   ADD TRANSACTION DIALOG
═══════════════════════════════════════ */
QDialog {
    background-color: #13131a;
}

QDialog QLabel#dialogTitle {
    font-size: 18px;
    font-weight: 700;
    color: #a78bfa;
    padding-bottom: 2px;
}

QDialog QFrame#divider {
    color: #1e1e2e;
    margin: 0;
}

QDialog QLabel {
    font-size: 11px;
    color: #6b7280;
    font-weight: 500;
    letter-spacing: 0.3px;
}

QDialog QLineEdit {
    background-color: #0f0f14;
    border: 1px solid #1e1e2e;
    border-radius: 8px;
    padding: 9px 12px;
    color: #e2e2e8;
    font-size: 13px;
    min-height: 16px;
}

QDialog QLineEdit:focus {
    border-color: #7c3aed;
}

QDialog QDoubleSpinBox {
    background-color: #0f0f14;
    border: 1px solid #1e1e2e;
    border-radius: 8px;
    padding: 9px 12px;
    color: #e2e2e8;
    font-size: 13px;
    min-height: 16px;
}

QDialog QDoubleSpinBox:focus {
    border-color: #7c3aed;
}

QDialog QDoubleSpinBox::up-button,
QDialog QDoubleSpinBox::down-button {
    background-color: #1e1e2e;
    border: none;
    width: 20px;
    border-radius: 4px;
}

QDialog QDoubleSpinBox::up-button:hover,
QDialog QDoubleSpinBox::down-button:hover {
    background-color: #2a2a3a;
}

QDialog QComboBox {
    background-color: #0f0f14;
    border: 1px solid #1e1e2e;
    border-radius: 8px;
    padding: 9px 12px;
    color: #e2e2e8;
    font-size: 13px;
    min-height: 16px;
}

QDialog QComboBox:focus {
    border-color: #7c3aed;
}

QDialog QComboBox::drop-down {
    border: none;
    width: 24px;
}

QDialog QComboBox QAbstractItemView {
    background-color: #13131f;
    border: 1px solid #252535;
    color: #e2e2e8;
    selection-background-color: #1e1e3f;
    selection-color: #a78bfa;
    padding: 4px;
    outline: none;
}

QDialog QDateEdit {
    background-color: #0f0f14;
    border: 1px solid #1e1e2e;
    border-radius: 8px;
    padding: 9px 12px;
    color: #e2e2e8;
    font-size: 13px;
    min-height: 16px;
}

QDialog QDateEdit:focus {
    border-color: #7c3aed;
}

QDialog QDateEdit::drop-down {
    background-color: #1e1e2e;
    border: none;
    width: 24px;
    border-radius: 0 8px 8px 0;
}

QDialog QPlainTextEdit {
    background-color: #0f0f14;
    border: 1px solid #1e1e2e;
    border-radius: 8px;
    padding: 8px 12px;
    color: #e2e2e8;
    font-size: 13px;
}

QDialog QPlainTextEdit:focus {
    border-color: #7c3aed;
}

/* ── BUTTONS — violet theme to match the whole app ── */
QPushButton#confirmBtn {
    background-color: #7c3aed;
    border: none;
    border-radius: 8px;
    padding: 11px 28px;
    color: white;
    font-size: 13px;
    font-weight: 700;
    min-height: 38px;
    min-width: 110px;
}

QPushButton#confirmBtn:hover {
    background-color: #6d28d9;
}

QPushButton#confirmBtn:pressed {
    background-color: #5b21b6;
}

QPushButton#cancelBtn {
    background-color: #1a1a28;
    border: 1px solid #2e2e4e;
    border-radius: 8px;
    padding: 11px 28px;
    color: #9ca3af;
    font-size: 13px;
    font-weight: 500;
    min-height: 38px;
    min-width: 110px;
}

QPushButton#cancelBtn:hover {
    background-color: #222235;
    color: #e2e2e8;
    border-color: #3e3e5e;
}</string>
